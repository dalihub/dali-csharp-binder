# Package Information for pkg-config

prefix=@PREFIX@
exec_prefix=@EXEC_PREFIX@
apiversion=@DALI_CSHARP_BINDER_VERSION@
libdir=@LIB_DIR@
includedir=@DEV_INCLUDE_PATH@

Name: DALi C# binder
Description: DALi C# binder Library for toolkit demo
Version: ${apiversion}
Libs: -L${libdir} -ldali2-csharp-binder-toolkit-demo
Cflags: -I${includedir}/dali-csharp-binder
